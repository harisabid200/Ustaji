# ─────────────────────────────────────────────
# Ustaji Server — Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit .env to git
# ─────────────────────────────────────────────

# Google Gemini AI API Key
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Google Maps API Key (for distance/geocoding — optional)
# Get from: https://console.cloud.google.com/apis
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Firebase Service Account (base64-encoded JSON)
# Generate in Firebase Console → Project Settings → Service Accounts → Generate new private key
# Then encode: base64 firebase-service-account.json
# On Mac/Linux: base64 -i firebase-service-account.json | tr -d '\n'
# On Windows:   [Convert]::ToBase64String([IO.File]::ReadAllBytes("firebase-service-account.json"))
FIREBASE_SERVICE_ACCOUNT_BASE64=your_base64_encoded_service_account_json_here

# Server port (default: 3000)
PORT=3000

# Node environment: development | production
NODE_ENV=development

# Comma-separated list of allowed CORS origins, or * for all
# Example: https://myapp.com,https://staging.myapp.com
ALLOWED_ORIGINS=*
